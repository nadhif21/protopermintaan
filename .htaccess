# Enable rewrite engine
RewriteEngine On

# Allow CORS for API
<IfModule mod_headers.c>
    Header set Access-Control-Allow-Origin "*"
    Header set Access-Control-Allow-Methods "GET, POST, OPTIONS"
    Header set Access-Control-Allow-Headers "Content-Type, X-Auth-Token"
    
    # Security headers
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>

# Handle OPTIONS request for CORS preflight
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^(.*)$ $1 [R=200,L]

# Prevent directory listing
Options -Indexes

# Set default charset
AddDefaultCharset UTF-8

# Mail environment (Hostinger SMTP)
# Ganti nilai di bawah sesuai mailbox Anda
<IfModule mod_env.c>
    SetEnv APP_ENV production
    SetEnv MAIL_HOST smtp.hostinger.com
    SetEnv MAIL_PORT 465
    SetEnv MAIL_ENCRYPTION ssl
    SetEnv MAIL_USERNAME andaladkorpkt@infoadkor.com
    SetEnv MAIL_PASSWORD Adkor2025!
    SetEnv MAIL_FROM_EMAIL andaladkorpkt@infoadkor.com
    SetEnv MAIL_FROM_NAME "Permintaan DOF"
    SetEnv MAIL_REPLY_TO andaladkorpkt@infoadkor.com
    SetEnv MAIL_SMTP_DEBUG 0
</IfModule>

# PHP settings for Hostinger (PHP 8.x)
<IfModule mod_php.c>
    php_value default_charset "UTF-8"
    php_value upload_max_filesize "10M"
    php_value post_max_size "10M"
    php_value max_execution_time "300"
    php_value max_input_time "300"
    php_value memory_limit "256M"
</IfModule>

# Protect sensitive files
<FilesMatch "\.(htaccess|htpasswd|ini|log|sh|sql|bak)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Protect config.php
<Files "config.php">
    Order Allow,Deny
    Deny from all
</Files>

# Force HTTPS (uncomment jika sudah setup SSL di Hostinger)
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Custom error pages (optional)
# ErrorDocument 404 /404.html
# ErrorDocument 500 /500.html

# ========================================
# CACHE CONTROL - Memastikan Browser Selalu Memuat Versi Terbaru
# ========================================

# Disable caching untuk file HTML - HARUS selalu fresh
<IfModule mod_headers.c>
    # File HTML - NO CACHE sama sekali
    <FilesMatch "\.(html|htm)$">
        Header unset ETag
        Header set Cache-Control "no-cache, no-store, must-revalidate, max-age=0, private"
        Header set Pragma "no-cache"
        Header set Expires "0"
        Header append Cache-Control "post-check=0, pre-check=0"
    </FilesMatch>
    
    # File CSS dan JS - Revalidate dengan version parameter
    # Browser akan request ulang jika versi berbeda karena query parameter v=
    <FilesMatch "\.(css|js)$">
        Header unset ETag
        Header set Cache-Control "no-cache, must-revalidate, max-age=0"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>
    
    # Tambahkan header untuk prevent proxy/CDN caching
    Header set Vary "Accept-Encoding"
    Header append Vary "User-Agent"
</IfModule>

# Disable ETag untuk prevent caching issues
<IfModule mod_headers.c>
    Header unset ETag
</IfModule>
FileETag None

# Force browser untuk revalidate SEMUA file
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 0 seconds"
    ExpiresByType text/html "access plus 0 seconds"
    ExpiresByType text/css "access plus 0 seconds"
    ExpiresByType application/javascript "access plus 0 seconds"
    ExpiresByType text/javascript "access plus 0 seconds"
    ExpiresByType application/json "access plus 0 seconds"
</IfModule>

# Disable browser caching via rewrite (backup method)
<IfModule mod_rewrite.c>
    # Tambahkan timestamp untuk file HTML saat diakses
    RewriteCond %{REQUEST_FILENAME} \.(html|htm)$ [NC]
    RewriteRule .* - [E=no-cache:1]
</IfModule>
